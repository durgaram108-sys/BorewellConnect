generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LandType {
  Agriculture
  Residential
  Commercial
}

enum RequestStatus {
  OPEN
  BOOKED
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  CONFIRMED
  PAID
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CompanyStatus {
  PENDING
  VERIFIED
}

enum OtpPurpose {
  CUSTOMER
  OWNER
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
}

model Customer {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?
  surname   String?
  address   String?
  state     String?
  district  String?
  mandal    String?
  village   String?
  pincode   String?
  createdAt DateTime @default(now())

  requests BorewellRequest[]
  bookings Booking[]
}

model Otp {
  id        String     @id @default(cuid())
  phone     String
  purpose   OtpPurpose
  code      String
  expiresAt DateTime
  verified  Boolean    @default(false)
  createdAt DateTime   @default(now())

  @@index([phone, purpose])
}

model Company {
  id                 String        @id @default(cuid())
  phone              String        @unique
  name               String
  ownerName          String
  ownerSurname       String        @default("")
  address            String        @default("")
  city               String
  state              String
  mandal             String        @default("")
  village            String        @default("")
  pincode            String        @default("")
  experienceYears    Int           @default(0)
  registrationNumber String        @default("")
  serviceAreas       String[]      @default([])
  machineTypes       String[]      @default([])
  maxDepthFt         Int           @default(0)
  rateCard           Int[]         @default([])
  casingRate6kg      Int           @default(0)
  casingRate8kg      Int           @default(0)
  casingRate10kg     Int           @default(0)
  casingRateIron     Int           @default(0)
  estimatedCompletion String       @default("3–4 days")
  availableDates     DateTime[]    @default([])
  status             CompanyStatus @default(PENDING)
  ratingAvg          Float         @default(4.5)
  baseLat            Float         @default(17.53)
  baseLng            Float         @default(78.12)
  createdAt          DateTime      @default(now())

  vehiclePhotos  VehiclePhoto[]
  borewellPhotos BorewellPhoto[]
  quotes         Quote[]
  bookings       Booking[]
}

model VehiclePhoto {
  id        String   @id @default(cuid())
  companyId String
  slot      String
  url       String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, slot])
}

model BorewellPhoto {
  id        String   @id @default(cuid())
  companyId String
  url       String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model BorewellRequest {
  id            String        @id @default(cuid())
  code          String        @unique
  customerId    String
  country       String        @default("India")
  state         String
  district      String
  mandal        String
  landType      LandType
  machineType   String
  depthFt       Int
  lat           Float
  lng           Float
  preferredDate DateTime
  status        RequestStatus @default(OPEN)
  createdAt     DateTime      @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  quotes   Quote[]
  booking  Booking?
}

model Quote {
  id                   String   @id @default(cuid())
  requestId            String
  companyId            String
  bandRates            Int[]    @default([])
  machineType          String
  estimatedCompletion  String
  casingRate6kg        Int      @default(0)
  casingRate8kg        Int      @default(0)
  casingRate10kg       Int      @default(0)
  casingRateIron       Int      @default(0)
  createdAt            DateTime @default(now())

  request BorewellRequest @relation(fields: [requestId], references: [id])
  company Company         @relation(fields: [companyId], references: [id])
  booking Booking?

  @@unique([requestId, companyId])
}

model Booking {
  id          String        @id @default(cuid())
  code        String        @unique
  requestId   String        @unique
  quoteId     String        @unique
  customerId  String
  companyId   String
  bandRates      Int[]         @default([])
  casingRate6kg  Int           @default(0)
  casingRate8kg  Int           @default(0)
  casingRate10kg Int           @default(0)
  casingRateIron Int           @default(0)
  casingType     String?
  casingFeet     Int?
  bookingFee     Int           @default(500)
  status         BookingStatus @default(CONFIRMED)
  createdAt      DateTime      @default(now())

  request  BorewellRequest @relation(fields: [requestId], references: [id])
  quote    Quote           @relation(fields: [quoteId], references: [id])
  customer Customer        @relation(fields: [customerId], references: [id])
  company  Company         @relation(fields: [companyId], references: [id])

  milestones  Milestone[]
  workUpdates WorkUpdate[]
  invoice     Invoice?
  review      Review?
  payment     Payment?
}

model Milestone {
  id          String    @id @default(cuid())
  bookingId   String
  label       String
  order       Int
  completedAt DateTime?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, order])
}

model WorkUpdate {
  id        String   @id @default(cuid())
  bookingId String
  label     String
  photoUrl  String?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Invoice {
  id        String   @id @default(cuid())
  code      String   @unique
  bookingId String   @unique
  lineItems Json
  total     Int
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  rating    Int
  text      String   @default("")
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Payment {
  id                String        @id @default(cuid())
  bookingId         String        @unique
  provider          String        @default("razorpay")
  orderId           String
  paymentId         String?
  amount            Int
  status            PaymentStatus @default(CREATED)
  createdAt         DateTime      @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

/// Crowd-sourced Mandal names, keyed under State + District. Grows organically —
/// whenever a customer or company saves a profile (or files a request) with a
/// Mandal not already here, it's recorded so the next person in that district
/// sees it as a dropdown suggestion instead of retyping it from scratch.
model MandalSuggestion {
  id        String   @id @default(cuid())
  state     String
  district  String
  mandal    String
  createdAt DateTime @default(now())

  @@unique([state, district, mandal])
  @@index([state, district])
}

/// Same idea as MandalSuggestion, one level deeper: Village names under State + District + Mandal.
model VillageSuggestion {
  id        String   @id @default(cuid())
  state     String
  district  String
  mandal    String
  village   String
  createdAt DateTime @default(now())

  @@unique([state, district, mandal, village])
  @@index([state, district, mandal])
}
