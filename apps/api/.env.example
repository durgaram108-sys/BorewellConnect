# PostgreSQL connection string
DATABASE_URL="postgresql://borewell:borewell@localhost:5432/borewell_connect?schema=public"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="30d"

# Server
PORT=4000
CORS_ORIGIN="*"

# MSG91 (OTP SMS) - https://control.msg91.com
# Leave MSG91_AUTH_KEY unset (or set MSG91_MOCK_OTP=true) to run in dev mode:
# OTPs are generated normally but logged to the server console instead of
# actually being sent, so you can develop without a live account.
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""
MSG91_MOCK_OTP=true

# Razorpay (payments) - https://dashboard.razorpay.com/app/keys
# Use your TEST mode keys (they start with rzp_test_). With no keys set,
# the API falls back to a mock order/verify flow so the booking flow is
# still testable end-to-end without a Razorpay account.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Seeded admin login (see prisma/seed.ts)
ADMIN_SEED_EMAIL="admin@borewellconnect.com"
ADMIN_SEED_PASSWORD="Admin@123"
